# ── MinIO environment file ─────────────────────────────────────────────────
# Copy this file to /etc/default/minio and fill in your values.
# NEVER commit the real /etc/default/minio — it contains credentials.

# Root (admin) credentials — change these before first start
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_use_a_long_random_string_32chars_min

# Storage path — must exist and be writable by minio-user
MINIO_VOLUMES=/data/minio

# Bind addresses — keep both on localhost; Nginx handles public access
# API port 9000, Console port 9001
MINIO_OPTS="--console-address 127.0.0.1:9001 --address 127.0.0.1:9000"
