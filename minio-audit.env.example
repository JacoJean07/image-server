# ══════════════════════════════════════════════════════════════════════════════
# MinIO Audit Logging Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Enable audit logging for compliance (GDPR, HIPAA, SOC2, PCI-DSS, etc.)
#
# Add these variables to /etc/default/minio and restart the service:
#   sudo systemctl restart minio
#
# Then monitor logs:
#   tail -f /var/log/syslog | grep minio
#   or journalctl -u minio -f
#
# ══════════════════════════════════════════════════════════════════════════════

# ── Option 1: Log to Syslog (Simplest - Recommended) ────────────────────────
# All MinIO API calls logged to system syslog with user, action, bucket, object

MINIO_AUDIT_WEBHOOK_ENABLE=on
MINIO_AUDIT_WEBHOOK_URL=syslog://localhost:514


# ── Option 2: Log to HTTP Webhook (For centralized logging) ─────────────────
# Send audit logs to an external logging service (ELK, Splunk, etc.)
# Requirements:
# - HTTP endpoint must be available and listening
# - Logs sent as JSON in POST requests
# - Endpoint must handle high volume during peak traffic

# MINIO_AUDIT_WEBHOOK_ENABLE=on
# MINIO_AUDIT_WEBHOOK_URL=https://your-logging-service.com/minio-audit
# MINIO_AUDIT_WEBHOOK_AUTH_TOKEN=your_auth_token_if_required


# ── Option 3: Log to Multiple Endpoints ───────────────────────────────────
# (MinIO supports multiple audit destinations)

# MINIO_AUDIT_WEBHOOK_ENABLE_syslog=on
# MINIO_AUDIT_WEBHOOK_URL_syslog=syslog://localhost:514

# MINIO_AUDIT_WEBHOOK_ENABLE_splunk=on
# MINIO_AUDIT_WEBHOOK_URL_splunk=https://splunk.example.com:8088/services/collector


# ── Option 4: Application-level Logging via Webhook ──────────────────────────
# Log to your application's audit endpoint

# MINIO_AUDIT_WEBHOOK_ENABLE_app=on
# MINIO_AUDIT_WEBHOOK_URL_app=http://127.0.0.1:3000/audit/minio


# ══════════════════════════════════════════════════════════════════════════════
# AUDIT LOG FORMAT
# ══════════════════════════════════════════════════════════════════════════════
#
# Each audit log entry contains:
# - timestamp (ISO 8601)
# - request_id (unique request identifier)
# - remote_host (client IP)
# - user_agent (client software)
# - response_status (HTTP status code)
# - error (if any)
# - bucket_name (MinIO bucket)
# - object_name (object key)
# - object_size (bytes)
# - request_path
# - request_method (GET, PUT, DELETE, etc.)
# - user_principal (access key used)
#
# Example syslog entry:
# minio[1234]: {"version":"1","decodedSuccessfully":true,"api":{"name":"GetObject",
# "bucket":"myapp-private","object":"secret.pdf","timeToResponseMs":45},
# "requestID":"EXAMPLE123","remotehost":"192.168.1.100","userAgent":"curl/7.68.0",
# "statusCode":206,"errorCode":"","errorMessage":""}


# ══════════════════════════════════════════════════════════════════════════════
# SYSLOG CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
#
# Default: Logs sent to local syslog daemon (rsyslog or journald)
#
# If you want to log to a remote syslog server:
#   MINIO_AUDIT_WEBHOOK_URL=syslog://remote-syslog.example.com:514
#
# Make sure rsyslog is configured to receive from MinIO:
#   /etc/rsyslog.d/minio.conf:
#
#   # Define input (if receiving from remote)
#   input(type="imudp" port="514" ruleset="minio_ruleset")
#
#   # Define ruleset
#   ruleset(name="minio_ruleset") {
#       action(type="omfile" file="/var/log/minio/audit.log")
#   }
#
# Then restart rsyslog:
#   sudo systemctl restart rsyslog


# ══════════════════════════════════════════════════════════════════════════════
# JSON REQUEST/RESPONSE LOGGING (Application-level)
# ══════════════════════════════════════════════════════════════════════════════
#
# MinIO can also log in JSON format for structured analysis
# Useful for ELK (Elasticsearch, Logstash, Kibana) or Splunk
#
# Enable JSON format output:
# MINIO_LOGGER=json


# ══════════════════════════════════════════════════════════════════════════════
# QUERYING AUDIT LOGS
# ══════════════════════════════════════════════════════════════════════════════
#
# View all MinIO activity:
#   sudo journalctl SYSLOG_IDENTIFIER=minio -f
#
# Find all GET requests:
#   sudo journalctl SYSLOG_IDENTIFIER=minio | grep '"GET"'
#
# Find all access by a specific user (access key):
#   sudo journalctl SYSLOG_IDENTIFIER=minio | grep 'myapp_app'
#
# Find all PUT/DELETE (write operations):
#   sudo journalctl SYSLOG_IDENTIFIER=minio | grep -E '"(PUT|DELETE)"'
#
# Find access to a specific bucket:
#   sudo journalctl SYSLOG_IDENTIFIER=minio | grep 'myapp-private'
#
# Count requests per user:
#   sudo journalctl SYSLOG_IDENTIFIER=minio | jq -r '.userPrincipal' | sort | uniq -c
#
# Find failed authentication attempts:
#   sudo journalctl SYSLOG_IDENTIFIER=minio | grep '"statusCode":"4'
#
# Export to JSON for external analysis:
#   sudo journalctl SYSLOG_IDENTIFIER=minio -o json > audit_logs.jsonl


# ══════════════════════════════════════════════════════════════════════════════
# COMPLIANCE & RETENTION
# ══════════════════════════════════════════════════════════════════════════════
#
# GDPR Compliance:
# - Retention: Typically 1-3 years depending on your data classification
# - Purge old logs: sudo journalctl SYSLOG_IDENTIFIER=minio --vacuum-time=90d
#
# HIPAA Compliance:
# - Retention: 6 years minimum recommended
# - Use encrypted syslog: syslog://user:password@syslog-server:514?tls=on
#
# PCI-DSS Compliance:
# - Retention: 1 year minimum
# - Off-site backup: Use a remote syslog server or cloud logging service
#
# SOC2 Compliance:
# - Immutable logs: Consider using a dedicated audit log sink
# - Alerting: Set up Fail2Ban or Prometheus to alert on suspicious patterns
#
# Configure log rotation in /etc/logrotate.d/minio:
#   /var/log/minio/*.log {
#       daily
#       missingok
#       rotate 365
#       compress
#       delaycompress
#       notifempty
#       create 0640 minio-user minio-user
#       sharedscripts
#   }


# ══════════════════════════════════════════════════════════════════════════════
# TROUBLESHOOTING
# ══════════════════════════════════════════════════════════════════════════════
#
# Logs not appearing?
#   1. Check if minio service is running: sudo systemctl status minio
#   2. Verify config was applied: sudo cat /etc/default/minio | grep AUDIT
#   3. Check if syslog is accepting logs: sudo tail -f /var/log/syslog
#   4. Restart MinIO: sudo systemctl restart minio
#   5. Check errors: sudo journalctl -u minio -n 100 --no-pager
#
# Too many logs (storage/performance issue)?
#   1. Reduce log verbosity (not recommended for compliance)
#   2. Increase syslog retention/rotation
#   3. Archive old logs to cold storage (S3, external backup)
#   4. Filter logs by severity at syslog level
#
# Logs not being received at remote server?
#   1. Test connectivity: nc -zv remote-syslog.example.com 514
#   2. Check firewall: sudo ufw allow 514/udp
#   3. Verify syslog server is listening: sudo ss -ulnp | grep :514
#   4. Check MinIO logs for errors: sudo journalctl -u minio -f


# ══════════════════════════════════════════════════════════════════════════════
# SECURITY CONSIDERATIONS
# ══════════════════════════════════════════════════════════════════════════════
#
# - Logs contain access information but NOT the file contents themselves
# - Use TLS for remote syslog: syslog+tls://remote-syslog:514
# - Restrict read access to audit logs: sudo chmod 640 /var/log/minio/*
# - Back up audit logs separately from application data
# - Never store audit logs in the same bucket (they should be immutable)
# - Consider using a dedicated audit logging service (e.g., Cloudflare Logpush)
#
# ══════════════════════════════════════════════════════════════════════════════
